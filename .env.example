# Diamond frontend — environment contract.
# Copy to `.env.local` for local dev, or set these in the Vercel project env.
#
# The app ships with an in-page MSW mock (src/mocks/) that fully drives the UI.
# That mock is PERMANENT infrastructure — it is Mike's backend test oracle and
# the API contract. Switching to the real backend is a TWO-FLAG FLIP, not a code
# change and NOT a removal of the mock. See docs/MIKE_HANDOFF.md (§2 + §10 + §15).

# --- Mock mode (default — what the live demo runs) -------------------------
# MSW patches window.fetch/XHR in-page (SW-free) and resolves same-origin /api.
NEXT_PUBLIC_MOCK_API=true
NEXT_PUBLIC_API_URL=/api

# --- Real backend (cutover) ------------------------------------------------
# Flip MOCK_API to false and point API_URL at Mike's Go backend. The mock code
# stays in the repo untouched — this just stops it intercepting. Rollback at any
# time by flipping MOCK_API back to true and redeploying.
# NEXT_PUBLIC_MOCK_API=false
# NEXT_PUBLIC_API_URL=https://api.diamond.example.com
