# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright e2e artifacts (specs + committed visual snapshots ARE tracked)
/test-results/
/playwright-report/
/blob-report/
/.playwright/
.last-run.json

# Run-2 reporter intermediates (regenerable via `npm run qa:run2`; RUN2.md IS tracked)
/docs/qa/run2-int.json
/docs/qa/run2-e2e.json
/docs/qa/run2-manual.jsonl

# next.js
/.next/
/out/

# production
/build

# build-time version manifest (regenerated by the `prebuild` hook on every
# build; src/lib/version.ts is the tracked twin that bakes into the bundle)
/public/version.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...except the committed env contract / template for the mock↔real-backend flip.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local vendor packages' installed deps (source is tracked, node_modules is not)
vendor/*/node_modules/

# masked-PAT capture artifacts from browser-automation sessions (SEC-7)
.playwright-mcp/

# local-only working artifacts (repo-cleanup 2026-07-17) — the "local == online 1-for-1"
# invariant: these stay on this machine, never in history. git add -A stays safe.
/Assets/
/Case Study/
/Things to work on/
/tmp/
/docs/dropdown-audit-2026-07-08/
/OVERHAUL_PROGRESS.md
/DOCK_GLIDE_PROGRESS.md
/admin-things-to-pay.png
