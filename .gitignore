# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright e2e artifacts (specs + committed visual snapshots ARE tracked)
/test-results/
/playwright-report/
/blob-report/
/.playwright/
.last-run.json

# Run-2 reporter intermediates (regenerable via `npm run qa:run2`; RUN2.md IS tracked)
/docs/qa/run2-int.json
/docs/qa/run2-e2e.json
/docs/qa/run2-manual.jsonl

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...except the committed env contract / template for the mock↔real-backend flip.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local vendor packages' installed deps (source is tracked, node_modules is not)
vendor/*/node_modules/
